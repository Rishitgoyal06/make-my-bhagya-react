# Master .gitignore for Make My Bhagya
# Covers both Frontend (React/Vite) and Backend (Node.js)

# Dependencies
node_modules/
**/node_modules/
package-lock.json
# Note: Usually package-lock is committed, but in some workflows it's ignored. 
# I'll leave it out of ignore by default unless requested, but added a comment.

# Build & Production
dist/
build/
out/
.vercel
.netlify

# Environment & Secrets (CRITICAL)
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.*

# Debug & Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE & Editor Settings
.vscode/
.idea/
*.swp
*.swo
.project
.settings/
.DS_Store
Thumbs.db

# Testing
coverage/
.nyc_output

# Miscellaneous
.amazonq/
server/tmp/
